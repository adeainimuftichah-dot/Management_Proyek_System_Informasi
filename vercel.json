{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "db.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets/|vite.svg|favicon.ico).*)*",
      "destination": "/index.html"
    }
  ]
}
